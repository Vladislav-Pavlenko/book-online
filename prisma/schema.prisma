generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ENUM
enum Gender {
  MALE
  FEMALE
  OTHER
}

// USER
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  fullName  String
  gender    Gender?
  birthDate DateTime?
  avatarUrl String?

  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments        Comment[]
  favorites       Favorite[]
  likes           Like[]
  addedBooks      Book[]            @relation("UserAddedBooks")
  readingProgress ReadingProgress[]
}

// BOOK
model Book {
  id          String    @id @default(cuid())
  title       String
  description String?
  publishedAt DateTime?

  coverData Bytes?
  fileData  Bytes?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?   @relation("UserAddedBooks", fields: [userId], references: [id], onDelete: SetNull)
  userId String?

  authors         BookAuthor[]
  categories      BookCategory[]
  comments        Comment[]
  likes           Like[]
  favorites       Favorite[]
  readingProgress ReadingProgress[]
}

// AUTHOR
model Author {
  id   String  @id @default(cuid())
  name String  @unique
  bio  String?

  books BookAuthor[]
}

// BOOK_AUTHOR (Many-to-Many)
model BookAuthor {
  bookId   String
  authorId String

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([bookId, authorId])
}

// CATEGORY
model Category {
  id   String @id @default(cuid())
  name String @unique

  books BookCategory[]
}

// BOOK_CATEGORY (Many-to-Many)
model BookCategory {
  bookId     String
  categoryId String

  book     Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([bookId, categoryId])
}

// COMMENT (Reviews)
model Comment {
  id        String   @id @default(cuid())
  content   String
  rating    Int?
  createdAt DateTime @default(now())

  userId String
  bookId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

// LIKE
model Like {
  userId String
  bookId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, bookId])
}

// FAVORITE (Bookmarks)
model Favorite {
  userId String
  bookId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, bookId])
}

// READING PROGRESS
model ReadingProgress {
  id          String   @id @default(cuid())
  userId      String
  bookId      String
  currentPage Int      @default(0)
  totalPages  Int?
  isFinished  Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}
